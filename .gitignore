# Binaries for programs and plugins
main
vanilla
*.exe
*.exe~
*.so
*.dylib
*.dll

# Ignore binary output folders
bin/

# Ignore common editor/system specific metadata
.DS_Store
.idea/
.vscode/
*.iml

# ENV
.env

# vweb and database
*.db
*.js
# ...but DO track the static_assets example's SPA bundle (a real, committed .js asset)
!examples/static_assets/dist/*.js

server_cert.pem
examples/tiny/src/src
examples/veb_like/veb_like

# generated at runtime by examples/video_stream
sample.mp4
*.mp4
*.log

# Compiled bench binaries: `v bench/<dir>/<name>.v` drops `<name>` beside the
# source (use `v run`, or `-o /tmp/...` as ci_bench.sh does, to avoid these).
# Sources stay tracked.
bench/etag_hash/etag_hash
bench/middleware/middleware_bench
bench/request_parser/request_parser_bench
bench/static_assets/static_assets_bench

# V build / profiling artifacts
*.tmp.c
perf.data
perf.data.old
callgrind.out.*
massif.out.*
